# Auto-detect text files, normalize line endings, and keep generated text stable.
* text=auto eol=lf

# Human-authored source and documentation are UTF-8 text.
*.md text eol=lf working-tree-encoding=UTF-8
*.py text eol=lf working-tree-encoding=UTF-8
*.cpp text eol=lf working-tree-encoding=UTF-8
*.h text eol=lf working-tree-encoding=UTF-8
*.ino text eol=lf working-tree-encoding=UTF-8
*.ini text eol=lf working-tree-encoding=UTF-8
*.json text eol=lf working-tree-encoding=UTF-8
