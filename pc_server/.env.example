# Never put this key in either ESP32 firmware.
OPENAI_API_KEY=sk-your-key-here

# Current defaults are configurable so a model change needs no firmware edit.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Must exactly match firmware/ai_audio_esp32/include/secrets.h
AREX_DEVICE_TOKEN=replace-with-a-long-random-token

AREX_HOST=0.0.0.0
AREX_PORT=8000
AREX_LOG_LEVEL=INFO
AREX_MAX_AUDIO_SECONDS=8
AREX_ENABLE_WAKE_WORD=true
AREX_WAKE_WORD=Arex
AREX_WAKE_WORD_ALIASES=arex,a rex,hey arex,hey a rex,alex
AREX_WAKE_WORD_REQUIRED_FOR_BUTTON=false

# Allow Arex to use OpenAI hosted web search for current facts and research.
# ESP32 firmware does not need your OpenAI key; only this PC server uses it.
AREX_ENABLE_WEB_SEARCH=true
AREX_WEB_SEARCH_CONTEXT_SIZE=low

# Local long-term memory. The file is ignored by Git because it may contain
# personal demo notes and preferences.
AREX_ENABLE_COGNEE=true
AREX_COGNEE_MEMORY_PATH=data/cognee_memory.json

