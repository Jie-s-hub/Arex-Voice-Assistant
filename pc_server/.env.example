# Never put this key in either ESP32 firmware.
OPENAI_API_KEY=sk-your-key-here

# Current defaults are configurable so a model change needs no firmware edit.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Must exactly match firmware/rover_esp32/include/secrets.h
ROVER_TOKEN=replace-with-a-long-random-token

AURA_HOST=0.0.0.0
AURA_PORT=8000
AURA_LOG_LEVEL=INFO
AURA_MAX_AUDIO_SECONDS=8

# Allow AURA to use OpenAI hosted web search for current facts and research.
# ESP32 firmware does not need your OpenAI key; only this PC server uses it.
AURA_ENABLE_WEB_SEARCH=true
AURA_WEB_SEARCH_CONTEXT_SIZE=low

# Local long-term memory. The file is ignored by Git because it may contain
# personal demo notes and preferences.
AURA_ENABLE_MEMORY=true
AURA_MEMORY_PATH=data/congee_memory.json
