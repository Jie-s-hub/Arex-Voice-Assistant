{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura-rover.local/schemas/home-command.schema.json",
  "title": "AURA smart-home command",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "request_id", "source", "command", "device", "state"],
  "properties": {
    "version": {"const": 1},
    "request_id": {"type": "string", "minLength": 8, "maxLength": 64},
    "source": {"type": "string", "minLength": 1, "maxLength": 64},
    "command": {"const": "set"},
    "device": {"enum": ["bedroom_light", "fan", "all"]},
    "state": {"enum": ["on", "off"]}
  },
  "allOf": [
    {
      "if": {"properties": {"device": {"const": "all"}}, "required": ["device"]},
      "then": {"properties": {"state": {"const": "off"}}}
    }
  ]
}

